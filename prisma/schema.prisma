generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Existing models (UNCHANGED) ─────────────────────────────────────────────

model InstitutionSchema {
  id                       String        @id @default(cuid())
  name                     String
  country                  String
  isGlobal                 Boolean       @default(true)
  createdByUserId          String?
  csvMapping               Json
  accounts                 Account[]
  preferredProvider        BankProvider?
  plaidInstitutionId       String?
  enableBankingAspspId     String?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
}

model Account {
  id                  String               @id @default(cuid())
  userId              String
  institutionSchemaId String
  institution         InstitutionSchema    @relation(fields: [institutionSchemaId], references: [id])
  name                String
  type                AccountType
  currency            String               @default("USD")
  lastImportAt        DateTime?
  transactions        Transaction[]
  importBatches       ImportBatch[]
  bankPlaybook        BankPlaybook?
  encryptedCredential EncryptedCredential?
  bankConnection      BankConnection?
  syncJobs            SyncJob[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([userId])
}

model CategoryGroup {
  id          String     @id @default(cuid())
  userId      String
  name        String
  sortOrder   Int        @default(0)
  scheduleRef String?
  taxType     String?
  categories  Category[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
}

model Category {
  id              String               @id @default(cuid())
  userId          String
  name            String
  groupId         String
  group           CategoryGroup        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sortOrder       Int                  @default(0)
  payees          Payee[]
  transactions    Transaction[]
  rules           CategorizationRule[]
  ruleSuggestions RuleSuggestion[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([userId])
}

model Payee {
  id                String               @id @default(cuid())
  userId            String
  name              String
  defaultCategoryId String?
  defaultCategory   Category?            @relation(fields: [defaultCategoryId], references: [id])
  transactions      Transaction[]
  rules             CategorizationRule[]
  ruleSuggestions   RuleSuggestion[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

model Transaction {
  id                        String                     @id @default(cuid())
  accountId                 String
  account                   Account                    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  workspaceId               String?                    @map("projectId")
  workspace                 Workspace?                 @relation(fields: [workspaceId], references: [id])
  importBatchId             String?
  importBatch               ImportBatch?               @relation(fields: [importBatchId], references: [id])
  categoryId                String?
  categoryRef               Category?                  @relation(fields: [categoryId], references: [id])
  payeeId                   String?
  payee                     Payee?                     @relation(fields: [payeeId], references: [id])
  date                      DateTime
  amount                    Decimal                    @db.Decimal(12, 2)
  description               String
  category                  String?
  tags                      String[]
  notes                     String?
  rawData                   Json
  duplicateHash             String                     @unique
  invoicePayment            InvoicePayment?
  invoicePaymentSuggestions InvoicePaymentSuggestion[]
  receipts                  Receipt[]
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  @@index([accountId, date])
  @@index([categoryId])
  @@index([payeeId])
  @@index([workspaceId])
}

model ImportBatch {
  id           String        @id @default(cuid())
  accountId    String
  account      Account       @relation(fields: [accountId], references: [id])
  filename     String
  rowCount     Int
  skippedCount Int           @default(0)
  transactions Transaction[]
  createdAt    DateTime      @default(now())
}

enum AccountType {
  CREDIT_CARD
  DEBIT_CARD
  CHECKING
  SAVINGS
  BUSINESS_CHECKING
  TRUST_ACCOUNT
}

model CategorizationRule {
  id           String    @id @default(cuid())
  userId       String
  name         String
  priority     Int       @default(50)
  conditions   Json
  categoryName String
  categoryId   String?
  categoryRef  Category? @relation(fields: [categoryId], references: [id])
  payeeId      String?
  payee        Payee?    @relation(fields: [payeeId], references: [id])
  workspaceId  String?   @map("projectId")
  workspace    Workspace? @relation(fields: [workspaceId], references: [id])
  setNotes     String?
  addTags      String[]  @default([])
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

model UserPreference {
  userId    String   @id
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt
}

model RuleSuggestion {
  id           String               @id @default(cuid())
  userId       String
  status       RuleSuggestionStatus @default(PENDING)
  conditions   Json
  categoryName String
  categoryId   String?
  categoryRef  Category?            @relation(fields: [categoryId], references: [id])
  payeeName    String?
  payeeId      String?
  payee        Payee?               @relation(fields: [payeeId], references: [id])
  confidence   String
  impact       String
  reasoning    String
  matchCount   Int                  @default(0)
  totalAmount  Decimal              @default(0) @db.Decimal(12, 2)
  sourceEdits  Json
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([userId, status])
}

enum RuleSuggestionStatus {
  PENDING
  ACCEPTED
  IGNORED
}

model BankPlaybook {
  id                  String    @id @default(cuid())
  accountId           String    @unique
  account             Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  loginUrl            String
  steps               Json
  exportPagePath      String?
  csvDownloadSelector String?
  twoFaType           String    @default("unknown")
  lastVerifiedAt      DateTime?
  status              String    @default("draft")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model EncryptedCredential {
  id         String   @id @default(cuid())
  accountId  String   @unique
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  ciphertext String
  iv         String
  authTag    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SyncJob {
  id               String          @id @default(cuid())
  accountId        String
  account          Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  status           SyncJobStatus   @default(PENDING)
  triggeredBy      String          @default("manual")
  startedAt        DateTime        @default(now())
  completedAt      DateTime?
  error            String?
  imported         Int?
  skipped          Int?
  batchId          String?
  provider         BankProvider?
  bankConnectionId String?
  bankConnection   BankConnection? @relation(fields: [bankConnectionId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([accountId])
}

enum BankProvider {
  PLAID
  ENABLE_BANKING
  BROWSER_AGENT
}

enum ConnectionStatus {
  ACTIVE
  DISCONNECTED
  DEGRADED
  REVOKED
}

model BankConnection {
  id                       String           @id @default(cuid())
  accountId                String           @unique
  account                  Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userId                   String
  provider                 BankProvider
  status                   ConnectionStatus @default(ACTIVE)
  // Plaid
  plaidItemId              String?
  plaidAccountId           String?
  plaidInstitutionId       String?
  // Enable Banking (UK + EU PSD2)
  enableBankingSessionId   String?
  enableBankingAccountId   String?
  enableBankingAspspId     String?
  // Shared encrypted token storage
  tokenCiphertext          String?
  tokenIv                  String?
  tokenAuthTag             String?
  // Refresh token (Finexer + Enable Banking use OAuth refresh)
  refreshCiphertext        String?
  refreshIv                String?
  refreshAuthTag           String?
  tokenExpiresAt           DateTime?
  lastSyncAt               DateTime?
  lastSyncCursor           String?
  errorCount               Int              @default(0)
  disconnectReason         String?
  metadata                 Json             @default("{}")
  syncJobs                 SyncJob[]
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  @@index([userId])
  @@index([plaidItemId])
  @@index([enableBankingSessionId])
}

enum SyncJobStatus {
  PENDING
  CONNECTING
  AWAITING_2FA
  DOWNLOADING
  IMPORTING
  COMPLETE
  FAILED
}

// ── Projects expansion (NEW) ────────────────────────────────────────────────

model Workspace {
  id                  String               @id @default(cuid())
  userId              String
  name                String
  slug                String
  type                WorkspaceType
  description         String?
  isActive            Boolean              @default(true)
  isDefault           Boolean              @default(false)
  clientProfile       ClientProfile?
  propertyProfile     PropertyProfile?
  transactions        Transaction[]
  categorizationRules CategorizationRule[]
  estimates           Estimate[]
  timeEntries         TimeEntry[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([userId, slug])
  @@index([userId])
  @@map("Project")
}

model TimeEntry {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  jobId       String?
  job         Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  date        DateTime  @db.Date
  minutes     Int
  description String
  billable    Boolean   @default(true)
  rate        Decimal?  @db.Decimal(10, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
  @@index([userId])
}

enum WorkspaceType {
  CLIENT
  PROPERTY
  OTHER

  @@map("ProjectType")
}

// ── Client track ────────────────────────────────────────────────────────────

model ClientProfile {
  id              String      @id @default(cuid())
  workspaceId     String      @unique @map("projectId")
  workspace       Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contactName     String?
  email           String?
  phone           String?
  company         String?
  address         String?
  billingType     BillingType @default(HOURLY)
  defaultRate     Decimal?    @db.Decimal(10, 2)
  currency        String      @default("USD")
  paymentTermDays Int         @default(30)
  jobs            Job[]
  invoices        Invoice[]
  quotes          Quote[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum BillingType {
  HOURLY
  FIXED
  RETAINER
  MILESTONE
}

model Job {
  id              String        @id @default(cuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  status          JobStatus     @default(ACTIVE)
  budgetAmount    Decimal?      @db.Decimal(12, 2)
  startDate       DateTime?
  endDate         DateTime?
  // Billing type override — null means inherit from ClientProfile
  billingType     BillingType?
  defaultRate     Decimal?      @db.Decimal(10, 2)
  // Actual cost for retrospective (manual entry or from tagged transactions)
  actualCost      Decimal?      @db.Decimal(12, 2)
  invoices        Invoice[]
  quotes          Quote[]
  estimates       Estimate[]    // legacy back-relation — new estimates use workspaceId directly
  timeEntries     TimeEntry[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([clientProfileId])
}

enum JobStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

// ── Invoice track ────────────────────────────────────────────────────────────

model Invoice {
  id                 String                     @id @default(cuid())
  clientProfileId    String?
  clientProfile      ClientProfile?             @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  jobId              String?
  job                Job?                       @relation(fields: [jobId], references: [id])
  // Property track FKs — set when clientProfileId is null
  leaseId            String?
  lease              Lease?                     @relation(fields: [leaseId], references: [id])
  tenantId           String?
  tenant             Tenant?                    @relation(fields: [tenantId], references: [id])
  applicantId        String?
  applicant          Applicant?                 @relation(fields: [applicantId], references: [id])
  invoiceNumber      String // e.g. "INV-0042" or "RENT-0001", auto-generated
  status             InvoiceStatus              @default(DRAFT)
  issueDate          DateTime                   @default(now())
  dueDate            DateTime
  currency           String                     @default("USD")
  notes              String?
  // NEW: period grouping for monthly rent invoices
  period             String? // e.g. "2026-04" for monthly grouping, null for ad-hoc
  autoGenerated      Boolean                    @default(false) // true = system-created rent invoice
  // Email tracking
  sentAt             DateTime?
  sentTo             String?
  reminderSentAt     DateTime?
  lineItems          InvoiceLineItem[]
  payments           InvoicePayment[]
  paymentSuggestions InvoicePaymentSuggestion[]
  // Renegotiation chain — one-to-one self-relation
  replacesInvoiceId  String?                    @unique
  replacesInvoice    Invoice?                   @relation("InvoiceReplacement", fields: [replacesInvoiceId], references: [id])
  replacedBy         Invoice?                   @relation("InvoiceReplacement")
  // Quote fulfillment link (optional — null for invoices created directly)
  quoteId            String?
  quote              Quote?                     @relation(fields: [quoteId], references: [id])
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@index([clientProfileId])
  @@index([leaseId])
  @@index([tenantId])
  @@index([applicantId])
  @@index([quoteId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  VOID
}

model InvoiceLineItem {
  id                   String              @id @default(cuid())
  invoiceId            String
  invoice              Invoice             @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description          String
  quantity             Decimal             @db.Decimal(10, 3)
  qtyUnit              String? // e.g. "hrs", "days", "words", "pages", "units"
  unitPrice            Decimal             @db.Decimal(10, 2)
  isTaxLine            Boolean             @default(false)
  chargeType           String? // property-track only: RENT, DEPOSIT, LATE_FEE, UTILITY, MAINTENANCE, OTHER
  createdAt            DateTime            @default(now())
  // NEW: forgiveness (migrated from TenantCharge)
  forgivenAt           DateTime?
  forgivenBy           String? // userId of manager who forgave
  forgivenReason       String?
  // NEW: optional back-link to source maintenance job (migrated from TenantCharge)
  maintenanceRequestId String?
  maintenanceRequest   MaintenanceRequest? @relation(fields: [maintenanceRequestId], references: [id])

  @@index([invoiceId])
}

model InvoicePayment {
  id            String       @id @default(cuid())
  invoiceId     String
  invoice       Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount        Decimal      @db.Decimal(10, 2)
  paidDate      DateTime
  paymentMethod String?
  notes         String?
  // Optional — null when recorded manually without a matched bank transaction
  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  createdAt     DateTime     @default(now())
  // NEW: voiding (migrated from TenantPayment)
  voidedAt      DateTime?
  voidedBy      String? // userId of manager who voided
  voidReason    String?
  // NEW: source deletion tracking (migrated from TenantPayment)
  sourceDeleted Boolean      @default(false) // true when linked transaction was deleted

  @@index([invoiceId])
}

// Suggested invoice payment attribution — created post-import, reviewed by user
model InvoicePaymentSuggestion {
  id            String                         @id @default(cuid())
  userId        String
  transactionId String
  transaction   Transaction                    @relation(fields: [transactionId], references: [id])
  invoiceId     String
  invoice       Invoice                        @relation(fields: [invoiceId], references: [id])
  confidence    String // 'high' | 'medium'
  reasoning     String
  status        InvoicePaymentSuggestionStatus @default(PENDING)
  createdAt     DateTime                       @default(now())
  updatedAt     DateTime                       @updatedAt

  @@index([userId, status])
  @@index([transactionId])
  @@index([invoiceId])
}

enum InvoicePaymentSuggestionStatus {
  PENDING
  ACCEPTED
  DISMISSED
}

// ── Property track ──────────────────────────────────────────────────────────

model PropertyProfile {
  id                      String       @id @default(cuid())
  workspaceId             String       @unique @map("projectId")
  workspace               Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  address                 String
  city                    String?
  state                   String?
  zipCode                 String?
  country                 String       @default("US")
  propertyType            PropertyType @default(RESIDENTIAL)
  yearBuilt               Int?
  squareFootage           Int?
  lotSize                 String?
  purchasePrice           Decimal?     @db.Decimal(12, 2)
  purchaseDate            DateTime?
  currentValue            Decimal?     @db.Decimal(12, 2)
  mortgageBalance         Decimal?     @db.Decimal(12, 2)
  requireLastMonth        Boolean      @default(false)
  autoGenerateRentInvoice Boolean      @default(false)
  units                   Unit[]
  applicants              Applicant[]
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
}

enum PropertyType {
  RESIDENTIAL
  MULTI_FAMILY
  COMMERCIAL
  MIXED_USE
  LAND
}

model Unit {
  id                  String               @id @default(cuid())
  propertyProfileId   String
  propertyProfile     PropertyProfile      @relation(fields: [propertyProfileId], references: [id], onDelete: Cascade)
  unitLabel           String
  status              UnitStatus           @default(VACANT)
  bedrooms            Int?
  bathrooms           Decimal?             @db.Decimal(3, 1)
  squareFootage       Int?
  monthlyRent         Decimal?             @db.Decimal(10, 2)
  leases              Lease[]
  maintenanceRequests MaintenanceRequest[]
  messages            Message[]
  applicants          Applicant[]
  listings            Listing[]
  showings            Showing[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([propertyProfileId])
}

enum UnitStatus {
  VACANT
  LEASED
  NOTICE_GIVEN
  PREPARING
  MAINTENANCE
  LISTED
}

model Lease {
  id                  String              @id @default(cuid())
  unitId              String
  unit                Unit                @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenantId            String
  tenant              Tenant              @relation(fields: [tenantId], references: [id])
  status              LeaseStatus         @default(DRAFT)
  startDate           DateTime
  endDate             DateTime
  monthlyRent         Decimal             @db.Decimal(10, 2)
  securityDeposit     Decimal?            @db.Decimal(10, 2)
  paymentDueDay       Int                 @default(1)
  lateFeeAmount       Decimal?            @db.Decimal(10, 2)
  lateFeeGraceDays    Int                 @default(5)
  // Contract management
  contractStatus      LeaseContractStatus @default(NONE)
  contractFileUrl     String?
  contractFileName    String?
  contractSentAt      DateTime?
  contractSignedAt    DateTime?
  contractNotes       String?
  // Currency for rent invoicing
  currency            String              @default("USD")
  // Applicant origin
  applicantId         String?
  applicant           Applicant?          @relation(fields: [applicantId], references: [id])
  // Rudimentary signing
  signingToken        String?             @unique
  tenantSignatureName String?
  tenantSignatureIp   String?
  tenantSignedAt      DateTime?
  ownerSignatureName  String?
  ownerSignedAt       DateTime?
  // Move-in milestone
  keysHandedOverAt    DateTime?
  // Lease addenda (JSON — immutable contract record)
  additionalCharges   Json                @default("[]") // [{label, amount, frequency: 'monthly'|'one_time'}]
  utilitiesIncluded   Json                @default("[]") // string[]
  leaseRules          Json                @default("{}") // {smokingAllowed, sublettingAllowed, petsAllowed, petNotes, parkingStall, parkingFee, storageUnit, storageFee, guestPolicy}
  // Renegotiation chain (mirrors Invoice.replacesInvoiceId pattern)
  replacesLeaseId     String?             @unique
  replacesLease       Lease?              @relation("LeaseReplacement", fields: [replacesLeaseId], references: [id])
  replacedBy          Lease?              @relation("LeaseReplacement")
  tenantFiles         TenantFile[]
  invoices            Invoice[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([unitId])
  @@index([tenantId])
}

enum LeaseContractStatus {
  NONE
  DRAFTING
  READY
  SENT
  SIGNED
  COUNTERSIGNED
}

enum LeaseStatus {
  DRAFT
  ACTIVE
  EXPIRING_SOON
  MONTH_TO_MONTH
  TERMINATED
  EXPIRED
}

model Tenant {
  id                     String               @id @default(cuid())
  userId                 String
  clerkUserId            String?
  name                   String
  email                  String
  phone                  String?
  emergencyName          String?
  emergencyPhone         String?
  portalInviteStatus     PortalInviteStatus   @default(NONE)
  leases                 Lease[]
  tenantFiles            TenantFile[]
  messages               Message[]
  maintenanceRequests    MaintenanceRequest[]
  invoices               Invoice[]
  convertedFromApplicant Applicant?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@unique([userId, email])
  @@index([userId])
}

enum PortalInviteStatus {
  NONE
  INVITED
  ACTIVE
}

model TenantFile {
  id         String         @id @default(cuid())
  tenantId   String
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leaseId    String?
  lease      Lease?         @relation(fields: [leaseId], references: [id])
  fileType   TenantFileType
  fileName   String
  fileUrl    String
  fileSize   Int?
  notes      String?
  uploadedBy String
  createdAt  DateTime       @default(now())
}

enum TenantFileType {
  LEASE_AGREEMENT
  ID_DOCUMENT
  PAY_STUB
  CREDIT_REPORT
  INSPECTION_REPORT
  MOVE_IN_PHOTOS
  MOVE_OUT_PHOTOS
  INSURANCE
  OTHER
}

model Message {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unitId         String
  unit           Unit     @relation(fields: [unitId], references: [id])
  subject        String?
  senderRole     String
  body           String
  isRead         Boolean  @default(false)
  attachmentUrl  String?
  attachmentName String?
  createdAt      DateTime @default(now())

  @@index([tenantId, unitId])
}

model MaintenanceRequest {
  id               String              @id @default(cuid())
  unitId           String
  unit             Unit                @relation(fields: [unitId], references: [id])
  tenantId         String?
  tenant           Tenant?             @relation(fields: [tenantId], references: [id])
  title            String
  description      String
  priority         MaintenancePriority @default(MEDIUM)
  status           MaintenanceStatus   @default(OPEN)
  scheduledDate    DateTime?
  completedDate    DateTime?
  cost             Decimal?            @db.Decimal(10, 2)
  vendorName       String?
  transactionId    String?
  invoiceLineItems InvoiceLineItem[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([unitId])
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

enum MaintenanceStatus {
  OPEN
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ── Applicant pipeline ───────────────────────────────────────────────────────

model Applicant {
  id                String          @id @default(cuid())
  userId            String // property owner
  propertyProfileId String
  propertyProfile   PropertyProfile @relation(fields: [propertyProfileId], references: [id], onDelete: Cascade)
  unitId            String?
  unit              Unit?           @relation(fields: [unitId], references: [id])

  // Contact info
  name  String
  email String
  phone String?

  // Application details
  status          ApplicantStatus @default(INQUIRY)
  source          String? // "zillow", "referral", "walk-in", etc.
  desiredMoveIn   DateTime?
  desiredRent     Decimal?        @db.Decimal(10, 2)
  currentEmployer String?
  annualIncome    Decimal?        @db.Decimal(12, 2)
  notes           String?

  // Screening
  creditScore     Int?
  backgroundCheck String? // "passed", "failed", "pending", null
  references      Json? // array of { name, phone, relationship }

  // Listing link
  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id])

  // Self-service application data
  applicationData Json? // structured form submission

  // Screening consent
  screeningConsentAt DateTime?
  screeningConsentIp String?

  // Future screening API integration (nullable placeholders)
  screeningRequestId String?
  screeningProvider  String?
  screeningReportUrl String?

  // Conversion
  convertedToTenantId String?   @unique
  convertedToTenant   Tenant?   @relation(fields: [convertedToTenantId], references: [id])
  convertedAt         DateTime?
  rejectedAt          DateTime?
  rejectedReason      String?

  documents ApplicantDocument[]
  showings  Showing[]
  leases    Lease[]
  invoices  Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([propertyProfileId])
  @@index([status])
}

enum ApplicantStatus {
  INQUIRY
  APPLICATION_SENT
  APPLIED
  SCREENING
  APPROVED
  LEASE_OFFERED
  LEASE_SIGNED
  REJECTED
  WITHDRAWN
}

model ApplicantDocument {
  id             String    @id @default(cuid())
  applicantId    String
  applicant      Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  fileType       String // "proof_of_income" | "proof_of_residence" | "government_id" | "bank_statement" | "employment_letter" | "reference_letter" | "other"
  requestLabel   String? // custom label when fileType = "other", or display override
  status         String    @default("uploaded") // "requested" | "uploaded"
  uploadToken    String?   @unique // HMAC token for ad-hoc upload links
  tokenExpiresAt DateTime?
  fileName       String    @default("")
  fileUrl        String    @default("")
  fileSize       Int?
  notes          String?
  uploadedBy     String    @default("") // userId or "applicant"
  createdAt      DateTime  @default(now())

  @@index([applicantId])
  @@index([uploadToken])
}

model Listing {
  id     String @id @default(cuid())
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  userId String // property owner, for auth scoping

  title         String
  description   String?
  monthlyRent   Decimal   @db.Decimal(10, 2)
  availableDate DateTime?
  petPolicy     String? // "allowed", "case-by-case", "no-pets"
  photos        Json      @default("[]") // string[] of URLs
  amenities     String? // free-text or comma-separated

  publicSlug String  @unique
  isActive   Boolean @default(true)

  applicationFee Decimal? @db.Decimal(10, 2)
  screeningFee   Decimal? @db.Decimal(10, 2)
  requiredDocs   Json     @default("[]") // string[] of doc type keys

  applicants Applicant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([unitId])
}

model Showing {
  id          String        @id @default(cuid())
  applicantId String
  applicant   Applicant     @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  unitId      String
  unit        Unit          @relation(fields: [unitId], references: [id])
  scheduledAt DateTime
  durationMin Int           @default(30)
  status      ShowingStatus @default(PROPOSED)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([applicantId])
  @@index([unitId])
}

enum ShowingStatus {
  PROPOSED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ── Estimate track ───────────────────────────────────────────────────────────

model Estimate {
  id          String            @id @default(cuid())
  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // Legacy: jobId kept nullable for existing data; new estimates leave this null
  jobId       String?
  job         Job?              @relation(fields: [jobId], references: [id], onDelete: SetNull)
  title       String
  status      EstimateStatus    @default(DRAFT)
  currency    String            @default("USD")
  notes       String?
  version     Int               @default(1)
  parentId    String?
  parent      Estimate?         @relation("EstimateVersions", fields: [parentId], references: [id])
  revisions   Estimate[]        @relation("EstimateVersions")
  quotes      Quote[]
  sections    EstimateSection[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([workspaceId])
}

enum EstimateStatus {
  DRAFT
  FINAL
  SUPERSEDED
}

model EstimateSection {
  id         String         @id @default(cuid())
  estimateId String
  estimate   Estimate       @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  name       String
  sortOrder  Int            @default(0)
  items      EstimateItem[]
  createdAt  DateTime       @default(now())

  @@index([estimateId])
}

model EstimateItem {
  id            String          @id @default(cuid())
  sectionId     String
  section       EstimateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  description   String
  hours         Decimal?        @db.Decimal(10, 2)
  costRate      Decimal?        @db.Decimal(10, 2)
  quantity      Decimal         @default(1) @db.Decimal(10, 3)
  unit          String?
  tags          String[]
  isOptional    Boolean         @default(false)
  internalNotes String?
  riskLevel     String?
  sortOrder     Int             @default(0)
  createdAt     DateTime        @default(now())

  @@index([sectionId])
}

// ── Quote track ──────────────────────────────────────────────────────────────

model Quote {
  id                String         @id @default(cuid())
  estimateId        String
  estimate          Estimate       @relation(fields: [estimateId], references: [id])
  jobId             String
  job               Job            @relation(fields: [jobId], references: [id])
  clientProfileId   String
  clientProfile     ClientProfile  @relation(fields: [clientProfileId], references: [id])
  quoteNumber       String
  title             String
  status            QuoteStatus    @default(DRAFT)
  version           Int            @default(1)
  currency          String         @default("USD")
  validUntil        DateTime?
  paymentSchedule   Json?
  scopeNotes        String?
  terms             String?
  notes             String?
  totalCost         Decimal?       @db.Decimal(12, 2)
  totalQuoted       Decimal?       @db.Decimal(12, 2)
  // Versioning chain
  previousVersionId String?        @unique
  previousVersion   Quote?         @relation("QuoteVersions", fields: [previousVersionId], references: [id])
  nextVersion       Quote?         @relation("QuoteVersions")
  // Amendment chain
  parentQuoteId     String?
  parentQuote       Quote?         @relation("QuoteAmendments", fields: [parentQuoteId], references: [id])
  amendments        Quote[]        @relation("QuoteAmendments")
  isAmendment       Boolean        @default(false)
  sections          QuoteSection[]
  invoices          Invoice[]
  // Override snapshot — preserves human decisions across regeneration
  overrides         Json?
  sentAt            DateTime?
  sentTo            String?
  signedAt          DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([jobId])
  @@index([clientProfileId])
  @@index([estimateId])
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  SUPERSEDED
  AMENDED
}

model QuoteSection {
  id        String          @id @default(cuid())
  quoteId   String
  quote     Quote           @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int             @default(0)
  items     QuoteLineItem[]
  createdAt DateTime        @default(now())

  @@index([quoteId])
}

model QuoteLineItem {
  id              String       @id @default(cuid())
  sectionId       String
  section         QuoteSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  description     String
  quantity        Decimal      @db.Decimal(10, 3)
  unit            String?
  unitPrice       Decimal      @db.Decimal(10, 2)
  isOptional      Boolean      @default(false)
  hasEstimateLink Boolean      @default(true)
  sortOrder       Int          @default(0)
  // Margin metadata (internal — never shown to client)
  costBasis       Decimal?     @db.Decimal(10, 2)
  marginPercent   Decimal?     @db.Decimal(5, 2)
  sourceItemIds   String[]
  createdAt       DateTime     @default(now())

  @@index([sectionId])
}

// ── Margin rules ─────────────────────────────────────────────────────────────

model MarginRule {
  id        String   @id @default(cuid())
  userId    String
  tag       String
  marginPct Decimal  @db.Decimal(5, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, tag])
  @@index([userId])
}

model Receipt {
  id             String        @id @default(cuid())
  userId         String
  transactionId  String?
  transaction    Transaction?  @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  status         ReceiptStatus @default(PROCESSING)
  thumbnailUrl   String?
  ocrMarkdown    String?
  extractedData  Json?
  originalHash   String
  originalSizeKb Int
  mimeType       String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([userId])
  @@index([transactionId])
}

enum ReceiptStatus {
  PROCESSING
  NEEDS_REVIEW
  COMPLETED
  FAILED
}
