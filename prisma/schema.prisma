generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Existing models (UNCHANGED) ─────────────────────────────────────────────

model InstitutionSchema {
  id                  String        @id @default(cuid())
  name                String
  country             String
  isGlobal            Boolean       @default(true)
  createdByUserId     String?
  csvMapping          Json
  accounts            Account[]
  preferredProvider   BankProvider?
  tellerInstitutionId String?
  plaidInstitutionId  String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Account {
  id                  String            @id @default(cuid())
  userId              String
  institutionSchemaId String
  institution         InstitutionSchema @relation(fields: [institutionSchemaId], references: [id])
  name                String
  type                AccountType
  currency            String            @default("USD")
  lastImportAt        DateTime?
  transactions        Transaction[]
  importBatches       ImportBatch[]
  bankPlaybook        BankPlaybook?
  encryptedCredential EncryptedCredential?
  bankConnection      BankConnection?
  syncJobs            SyncJob[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([userId])
}

model CategoryGroup {
  id          String     @id @default(cuid())
  userId      String
  name        String
  sortOrder   Int        @default(0)
  scheduleRef String?
  taxType     String?
  categories  Category[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
}

model Category {
  id              String               @id @default(cuid())
  userId          String
  name            String
  groupId         String
  group           CategoryGroup        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sortOrder       Int                  @default(0)
  payees          Payee[]
  transactions    Transaction[]
  rules           CategorizationRule[]
  ruleSuggestions RuleSuggestion[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([userId])
}

model Payee {
  id                String        @id @default(cuid())
  userId            String
  name              String
  defaultCategoryId String?
  defaultCategory   Category?     @relation(fields: [defaultCategoryId], references: [id])
  transactions      Transaction[]
  rules             CategorizationRule[]
  ruleSuggestions   RuleSuggestion[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([userId])
  @@unique([userId, name])
}

model Transaction {
  id            String       @id @default(cuid())
  accountId     String
  account       Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  projectId     String?
  project       Project?     @relation(fields: [projectId], references: [id])
  importBatchId String?
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id])
  categoryId    String?
  categoryRef   Category?    @relation(fields: [categoryId], references: [id])
  payeeId       String?
  payee         Payee?       @relation(fields: [payeeId], references: [id])
  date          DateTime
  amount        Decimal      @db.Decimal(12, 2)
  description   String
  category      String?
  tags          String[]
  notes         String?
  rawData       Json
  duplicateHash String       @unique
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([accountId, date])
  @@index([categoryId])
  @@index([payeeId])
  @@index([projectId])
}

model ImportBatch {
  id           String        @id @default(cuid())
  accountId    String
  account      Account       @relation(fields: [accountId], references: [id])
  filename     String
  rowCount     Int
  skippedCount Int           @default(0)
  transactions Transaction[]
  createdAt    DateTime      @default(now())
}

enum AccountType {
  CREDIT_CARD
  DEBIT_CARD
  CHECKING
  SAVINGS
  BUSINESS_CHECKING
  TRUST_ACCOUNT
}

model CategorizationRule {
  id           String    @id @default(cuid())
  userId       String
  name         String
  priority     Int       @default(50)
  conditions   Json
  categoryName String
  categoryId   String?
  categoryRef  Category? @relation(fields: [categoryId], references: [id])
  payeeId      String?
  payee        Payee?    @relation(fields: [payeeId], references: [id])
  projectId    String?
  project      Project?  @relation(fields: [projectId], references: [id])
  setNotes     String?
  addTags      String[]  @default([])
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

model UserPreference {
  userId    String   @id
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt
}

model RuleSuggestion {
  id           String           @id @default(cuid())
  userId       String
  status       RuleSuggestionStatus @default(PENDING)
  conditions   Json
  categoryName String
  categoryId   String?
  categoryRef  Category?        @relation(fields: [categoryId], references: [id])
  payeeName    String?
  payeeId      String?
  payee        Payee?           @relation(fields: [payeeId], references: [id])
  confidence   String
  impact       String
  reasoning    String
  matchCount   Int              @default(0)
  totalAmount  Decimal          @default(0) @db.Decimal(12, 2)
  sourceEdits  Json
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([userId, status])
}

enum RuleSuggestionStatus {
  PENDING
  ACCEPTED
  IGNORED
}

model BankPlaybook {
  id                  String    @id @default(cuid())
  accountId           String    @unique
  account             Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  loginUrl            String
  steps               Json
  exportPagePath      String?
  csvDownloadSelector String?
  twoFaType           String    @default("unknown")
  lastVerifiedAt      DateTime?
  status              String    @default("draft")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model EncryptedCredential {
  id          String   @id @default(cuid())
  accountId   String   @unique
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  ciphertext  String
  iv          String
  authTag     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SyncJob {
  id               String          @id @default(cuid())
  accountId        String
  account          Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  status           SyncJobStatus   @default(PENDING)
  triggeredBy      String          @default("manual")
  startedAt        DateTime        @default(now())
  completedAt      DateTime?
  error            String?
  imported         Int?
  skipped          Int?
  batchId          String?
  provider         BankProvider?
  bankConnectionId String?
  bankConnection   BankConnection? @relation(fields: [bankConnectionId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([accountId])
}

enum BankProvider {
  TELLER
  PLAID
  BROWSER_AGENT
}

enum ConnectionStatus {
  ACTIVE
  DISCONNECTED
  DEGRADED
  REVOKED
}

model BankConnection {
  id                   String           @id @default(cuid())
  accountId            String           @unique
  account              Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userId               String
  provider             BankProvider
  status               ConnectionStatus @default(ACTIVE)
  tellerEnrollmentId   String?
  tellerAccountId      String?
  tellerInstitutionId  String?
  plaidItemId          String?
  plaidAccountId       String?
  plaidInstitutionId   String?
  tokenCiphertext      String?
  tokenIv              String?
  tokenAuthTag         String?
  lastSyncAt           DateTime?
  lastSyncCursor       String?
  errorCount           Int              @default(0)
  disconnectReason     String?
  metadata             Json             @default("{}")
  syncJobs             SyncJob[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([userId])
  @@index([tellerEnrollmentId])
  @@index([plaidItemId])
}

enum SyncJobStatus {
  PENDING
  CONNECTING
  AWAITING_2FA
  DOWNLOADING
  IMPORTING
  COMPLETE
  FAILED
}

// ── Projects expansion (NEW) ────────────────────────────────────────────────

model Project {
  id                    String              @id @default(cuid())
  userId                String
  name                  String
  slug                  String
  type                  ProjectType
  description           String?
  isActive              Boolean             @default(true)
  clientProfile         ClientProfile?
  propertyProfile       PropertyProfile?
  transactions          Transaction[]
  categorizationRules   CategorizationRule[]
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@unique([userId, slug])
  @@index([userId])
}

enum ProjectType {
  CLIENT
  PROPERTY
  OTHER
}

// ── Client track ────────────────────────────────────────────────────────────

model ClientProfile {
  id              String      @id @default(cuid())
  projectId       String      @unique
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contactName     String?
  email           String?
  phone           String?
  company         String?
  address         String?
  billingType     BillingType @default(HOURLY)
  defaultRate     Decimal?    @db.Decimal(10, 2)
  currency        String      @default("USD")
  paymentTermDays Int         @default(30)
  jobs            Job[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum BillingType {
  HOURLY
  FIXED
  RETAINER
  MILESTONE
}

model Job {
  id              String        @id @default(cuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  status          JobStatus     @default(ACTIVE)
  budgetAmount    Decimal?      @db.Decimal(12, 2)
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([clientProfileId])
}

enum JobStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

// ── Property track ──────────────────────────────────────────────────────────

model PropertyProfile {
  id              String       @id @default(cuid())
  projectId       String       @unique
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  address         String
  city            String?
  state           String?
  zipCode         String?
  country         String       @default("US")
  propertyType    PropertyType @default(RESIDENTIAL)
  yearBuilt       Int?
  squareFootage   Int?
  lotSize         String?
  purchasePrice   Decimal?     @db.Decimal(12, 2)
  purchaseDate    DateTime?
  currentValue    Decimal?     @db.Decimal(12, 2)
  mortgageBalance Decimal?     @db.Decimal(12, 2)
  units           Unit[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

enum PropertyType {
  RESIDENTIAL
  MULTI_FAMILY
  COMMERCIAL
  MIXED_USE
  LAND
}

model Unit {
  id                  String               @id @default(cuid())
  propertyProfileId   String
  propertyProfile     PropertyProfile      @relation(fields: [propertyProfileId], references: [id], onDelete: Cascade)
  unitLabel           String
  status              UnitStatus           @default(VACANT)
  bedrooms            Int?
  bathrooms           Decimal?             @db.Decimal(3, 1)
  squareFootage       Int?
  monthlyRent         Decimal?             @db.Decimal(10, 2)
  leases              Lease[]
  maintenanceRequests MaintenanceRequest[]
  messages            Message[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([propertyProfileId])
}

enum UnitStatus {
  VACANT
  LEASED
  NOTICE_GIVEN
  PREPARING
  MAINTENANCE
  LISTED
}

model Lease {
  id               String      @id @default(cuid())
  unitId           String
  unit             Unit        @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenantId         String
  tenant           Tenant      @relation(fields: [tenantId], references: [id])
  status           LeaseStatus @default(DRAFT)
  startDate        DateTime
  endDate          DateTime
  monthlyRent      Decimal     @db.Decimal(10, 2)
  securityDeposit  Decimal?    @db.Decimal(10, 2)
  paymentDueDay    Int         @default(1)
  lateFeeAmount    Decimal?    @db.Decimal(10, 2)
  lateFeeGraceDays Int         @default(5)
  rentPayments     RentPayment[]
  tenantFiles      TenantFile[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([unitId])
  @@index([tenantId])
}

enum LeaseStatus {
  DRAFT
  ACTIVE
  EXPIRING_SOON
  MONTH_TO_MONTH
  TERMINATED
  EXPIRED
}

model Tenant {
  id                  String              @id @default(cuid())
  userId              String
  clerkUserId         String?
  name                String
  email               String
  phone               String?
  emergencyName       String?
  emergencyPhone      String?
  portalInviteStatus  PortalInviteStatus  @default(NONE)
  leases              Lease[]
  tenantFiles         TenantFile[]
  messages            Message[]
  rentPayments        RentPayment[]
  maintenanceRequests MaintenanceRequest[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([userId])
  @@unique([userId, email])
}

enum PortalInviteStatus {
  NONE
  INVITED
  ACTIVE
}

model TenantFile {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leaseId     String?
  lease       Lease?         @relation(fields: [leaseId], references: [id])
  fileType    TenantFileType
  fileName    String
  fileUrl     String
  fileSize    Int?
  notes       String?
  uploadedBy  String
  createdAt   DateTime       @default(now())
}

enum TenantFileType {
  LEASE_AGREEMENT
  ID_DOCUMENT
  PAY_STUB
  CREDIT_REPORT
  INSPECTION_REPORT
  MOVE_IN_PHOTOS
  MOVE_OUT_PHOTOS
  INSURANCE
  OTHER
}

model Message {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unitId         String
  unit           Unit     @relation(fields: [unitId], references: [id])
  senderRole     String
  body           String
  isRead         Boolean  @default(false)
  attachmentUrl  String?
  attachmentName String?
  createdAt      DateTime @default(now())

  @@index([tenantId, unitId])
}

model RentPayment {
  id                    String        @id @default(cuid())
  leaseId               String
  lease                 Lease         @relation(fields: [leaseId], references: [id])
  tenantId              String
  tenant                Tenant        @relation(fields: [tenantId], references: [id])
  amount                Decimal       @db.Decimal(10, 2)
  dueDate               DateTime
  paidDate              DateTime?
  status                PaymentStatus @default(PENDING)
  stripePaymentIntentId String?
  stripeInvoiceId       String?
  paymentMethod         String?
  transactionId         String?
  lateFeeApplied        Decimal?      @db.Decimal(10, 2)
  notes                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([leaseId])
  @@index([tenantId])
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  LATE
  PARTIAL
  FAILED
  WAIVED
}

model MaintenanceRequest {
  id            String              @id @default(cuid())
  unitId        String
  unit          Unit                @relation(fields: [unitId], references: [id])
  tenantId      String?
  tenant        Tenant?             @relation(fields: [tenantId], references: [id])
  title         String
  description   String
  priority      MaintenancePriority @default(MEDIUM)
  status        MaintenanceStatus   @default(OPEN)
  scheduledDate DateTime?
  completedDate DateTime?
  cost          Decimal?            @db.Decimal(10, 2)
  vendorName    String?
  transactionId String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([unitId])
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

enum MaintenanceStatus {
  OPEN
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
