generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Existing models (UNCHANGED) ─────────────────────────────────────────────

model InstitutionSchema {
  id                  String        @id @default(cuid())
  name                String
  country             String
  isGlobal            Boolean       @default(true)
  createdByUserId     String?
  csvMapping          Json
  accounts            Account[]
  preferredProvider   BankProvider?
  tellerInstitutionId String?
  plaidInstitutionId  String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Account {
  id                  String            @id @default(cuid())
  userId              String
  institutionSchemaId String
  institution         InstitutionSchema @relation(fields: [institutionSchemaId], references: [id])
  name                String
  type                AccountType
  currency            String            @default("USD")
  lastImportAt        DateTime?
  transactions        Transaction[]
  importBatches       ImportBatch[]
  bankPlaybook        BankPlaybook?
  encryptedCredential EncryptedCredential?
  bankConnection      BankConnection?
  syncJobs            SyncJob[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([userId])
}

model CategoryGroup {
  id          String     @id @default(cuid())
  userId      String
  name        String
  sortOrder   Int        @default(0)
  scheduleRef String?
  taxType     String?
  categories  Category[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
}

model Category {
  id              String               @id @default(cuid())
  userId          String
  name            String
  groupId         String
  group           CategoryGroup        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sortOrder       Int                  @default(0)
  payees          Payee[]
  transactions    Transaction[]
  rules           CategorizationRule[]
  ruleSuggestions RuleSuggestion[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([userId])
}

model Payee {
  id                String        @id @default(cuid())
  userId            String
  name              String
  defaultCategoryId String?
  defaultCategory   Category?     @relation(fields: [defaultCategoryId], references: [id])
  transactions      Transaction[]
  rules             CategorizationRule[]
  ruleSuggestions   RuleSuggestion[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([userId])
  @@unique([userId, name])
}

model Transaction {
  id            String       @id @default(cuid())
  accountId     String
  account       Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  projectId     String?
  project       Project?     @relation(fields: [projectId], references: [id])
  importBatchId String?
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id])
  categoryId    String?
  categoryRef   Category?    @relation(fields: [categoryId], references: [id])
  payeeId       String?
  payee         Payee?       @relation(fields: [payeeId], references: [id])
  date          DateTime
  amount        Decimal      @db.Decimal(12, 2)
  description   String
  category      String?
  tags          String[]
  notes         String?
  rawData       Json
  duplicateHash            String                    @unique
  tenantPayment             TenantPayment?
  tenantPaymentSuggestions  TenantPaymentSuggestion[]
  invoicePayment            InvoicePayment?
  invoicePaymentSuggestions InvoicePaymentSuggestion[]
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  @@index([accountId, date])
  @@index([categoryId])
  @@index([payeeId])
  @@index([projectId])
}

model ImportBatch {
  id           String        @id @default(cuid())
  accountId    String
  account      Account       @relation(fields: [accountId], references: [id])
  filename     String
  rowCount     Int
  skippedCount Int           @default(0)
  transactions Transaction[]
  createdAt    DateTime      @default(now())
}

enum AccountType {
  CREDIT_CARD
  DEBIT_CARD
  CHECKING
  SAVINGS
  BUSINESS_CHECKING
  TRUST_ACCOUNT
}

model CategorizationRule {
  id           String    @id @default(cuid())
  userId       String
  name         String
  priority     Int       @default(50)
  conditions   Json
  categoryName String
  categoryId   String?
  categoryRef  Category? @relation(fields: [categoryId], references: [id])
  payeeId      String?
  payee        Payee?    @relation(fields: [payeeId], references: [id])
  projectId    String?
  project      Project?  @relation(fields: [projectId], references: [id])
  setNotes     String?
  addTags      String[]  @default([])
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

model UserPreference {
  userId    String   @id
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt
}

model RuleSuggestion {
  id           String           @id @default(cuid())
  userId       String
  status       RuleSuggestionStatus @default(PENDING)
  conditions   Json
  categoryName String
  categoryId   String?
  categoryRef  Category?        @relation(fields: [categoryId], references: [id])
  payeeName    String?
  payeeId      String?
  payee        Payee?           @relation(fields: [payeeId], references: [id])
  confidence   String
  impact       String
  reasoning    String
  matchCount   Int              @default(0)
  totalAmount  Decimal          @default(0) @db.Decimal(12, 2)
  sourceEdits  Json
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([userId, status])
}

enum RuleSuggestionStatus {
  PENDING
  ACCEPTED
  IGNORED
}

model BankPlaybook {
  id                  String    @id @default(cuid())
  accountId           String    @unique
  account             Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  loginUrl            String
  steps               Json
  exportPagePath      String?
  csvDownloadSelector String?
  twoFaType           String    @default("unknown")
  lastVerifiedAt      DateTime?
  status              String    @default("draft")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model EncryptedCredential {
  id          String   @id @default(cuid())
  accountId   String   @unique
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  ciphertext  String
  iv          String
  authTag     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SyncJob {
  id               String          @id @default(cuid())
  accountId        String
  account          Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  status           SyncJobStatus   @default(PENDING)
  triggeredBy      String          @default("manual")
  startedAt        DateTime        @default(now())
  completedAt      DateTime?
  error            String?
  imported         Int?
  skipped          Int?
  batchId          String?
  provider         BankProvider?
  bankConnectionId String?
  bankConnection   BankConnection? @relation(fields: [bankConnectionId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([accountId])
}

enum BankProvider {
  TELLER
  PLAID
  BROWSER_AGENT
}

enum ConnectionStatus {
  ACTIVE
  DISCONNECTED
  DEGRADED
  REVOKED
}

model BankConnection {
  id                   String           @id @default(cuid())
  accountId            String           @unique
  account              Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userId               String
  provider             BankProvider
  status               ConnectionStatus @default(ACTIVE)
  tellerEnrollmentId   String?
  tellerAccountId      String?
  tellerInstitutionId  String?
  plaidItemId          String?
  plaidAccountId       String?
  plaidInstitutionId   String?
  tokenCiphertext      String?
  tokenIv              String?
  tokenAuthTag         String?
  lastSyncAt           DateTime?
  lastSyncCursor       String?
  errorCount           Int              @default(0)
  disconnectReason     String?
  metadata             Json             @default("{}")
  syncJobs             SyncJob[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([userId])
  @@index([tellerEnrollmentId])
  @@index([plaidItemId])
}

enum SyncJobStatus {
  PENDING
  CONNECTING
  AWAITING_2FA
  DOWNLOADING
  IMPORTING
  COMPLETE
  FAILED
}

// ── Projects expansion (NEW) ────────────────────────────────────────────────

model Project {
  id                    String              @id @default(cuid())
  userId                String
  name                  String
  slug                  String
  type                  ProjectType
  description           String?
  isActive              Boolean             @default(true)
  clientProfile         ClientProfile?
  propertyProfile       PropertyProfile?
  transactions          Transaction[]
  categorizationRules   CategorizationRule[]
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@unique([userId, slug])
  @@index([userId])
}

enum ProjectType {
  CLIENT
  PROPERTY
  OTHER
}

// ── Client track ────────────────────────────────────────────────────────────

model ClientProfile {
  id              String      @id @default(cuid())
  projectId       String      @unique
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contactName     String?
  email           String?
  phone           String?
  company         String?
  address         String?
  billingType     BillingType @default(HOURLY)
  defaultRate     Decimal?    @db.Decimal(10, 2)
  currency        String      @default("USD")
  paymentTermDays Int         @default(30)
  jobs            Job[]
  invoices        Invoice[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum BillingType {
  HOURLY
  FIXED
  RETAINER
  MILESTONE
}

model Job {
  id              String        @id @default(cuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  status          JobStatus     @default(ACTIVE)
  budgetAmount    Decimal?      @db.Decimal(12, 2)
  startDate       DateTime?
  endDate         DateTime?
  invoices        Invoice[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([clientProfileId])
}

enum JobStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

// ── Invoice track ────────────────────────────────────────────────────────────

model Invoice {
  id              String            @id @default(cuid())
  clientProfileId String?
  clientProfile   ClientProfile?    @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  jobId           String?
  job             Job?              @relation(fields: [jobId], references: [id])
  // Property track FKs — set when clientProfileId is null
  leaseId         String?
  lease           Lease?            @relation(fields: [leaseId], references: [id])
  tenantId        String?
  tenant          Tenant?           @relation(fields: [tenantId], references: [id])
  applicantId     String?
  applicant       Applicant?        @relation(fields: [applicantId], references: [id])
  invoiceNumber   String            // e.g. "INV-0042" or "RENT-0001", auto-generated
  status          InvoiceStatus     @default(DRAFT)
  issueDate       DateTime          @default(now())
  dueDate         DateTime
  currency        String            @default("USD")
  notes           String?
  // Email tracking
  sentAt          DateTime?
  sentTo          String?
  reminderSentAt  DateTime?
  lineItems          InvoiceLineItem[]
  payments           InvoicePayment[]
  paymentSuggestions InvoicePaymentSuggestion[]
  // Renegotiation chain — one-to-one self-relation
  replacesInvoiceId  String?           @unique
  replacesInvoice    Invoice?          @relation("InvoiceReplacement", fields: [replacesInvoiceId], references: [id])
  replacedBy         Invoice?          @relation("InvoiceReplacement")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([clientProfileId])
  @@index([leaseId])
  @@index([tenantId])
  @@index([applicantId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  VOID
}

model InvoiceLineItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal  @db.Decimal(10, 3)
  unitPrice   Decimal  @db.Decimal(10, 2)
  isTaxLine   Boolean  @default(false)
  chargeType  String?  // property-track only: RENT, DEPOSIT, LATE_FEE, UTILITY, MAINTENANCE, OTHER
  createdAt   DateTime @default(now())

  @@index([invoiceId])
}

model InvoicePayment {
  id            String       @id @default(cuid())
  invoiceId     String
  invoice       Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount        Decimal      @db.Decimal(10, 2)
  paidDate      DateTime
  paymentMethod String?
  notes         String?
  // Optional — null when recorded manually without a matched bank transaction
  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  createdAt     DateTime     @default(now())

  @@index([invoiceId])
}

// Suggested invoice payment attribution — created post-import, reviewed by user
model InvoicePaymentSuggestion {
  id            String                          @id @default(cuid())
  userId        String
  transactionId String
  transaction   Transaction                     @relation(fields: [transactionId], references: [id])
  invoiceId     String
  invoice       Invoice                         @relation(fields: [invoiceId], references: [id])
  confidence    String                          // 'high' | 'medium'
  reasoning     String
  status        InvoicePaymentSuggestionStatus  @default(PENDING)
  createdAt     DateTime                        @default(now())
  updatedAt     DateTime                        @updatedAt

  @@index([userId, status])
  @@index([transactionId])
  @@index([invoiceId])
}

enum InvoicePaymentSuggestionStatus {
  PENDING
  ACCEPTED
  DISMISSED
}

// ── Property track ──────────────────────────────────────────────────────────

model PropertyProfile {
  id                       String       @id @default(cuid())
  projectId                String       @unique
  project                  Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  address                  String
  city                     String?
  state                    String?
  zipCode                  String?
  country                  String       @default("US")
  propertyType             PropertyType @default(RESIDENTIAL)
  yearBuilt                Int?
  squareFootage            Int?
  lotSize                  String?
  purchasePrice            Decimal?     @db.Decimal(12, 2)
  purchaseDate             DateTime?
  currentValue             Decimal?     @db.Decimal(12, 2)
  mortgageBalance          Decimal?     @db.Decimal(12, 2)
  requireLastMonth         Boolean      @default(false)
  autoGenerateRentInvoice  Boolean      @default(false)
  units                    Unit[]
  applicants               Applicant[]
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
}

enum PropertyType {
  RESIDENTIAL
  MULTI_FAMILY
  COMMERCIAL
  MIXED_USE
  LAND
}

model Unit {
  id                  String               @id @default(cuid())
  propertyProfileId   String
  propertyProfile     PropertyProfile      @relation(fields: [propertyProfileId], references: [id], onDelete: Cascade)
  unitLabel           String
  status              UnitStatus           @default(VACANT)
  bedrooms            Int?
  bathrooms           Decimal?             @db.Decimal(3, 1)
  squareFootage       Int?
  monthlyRent         Decimal?             @db.Decimal(10, 2)
  leases              Lease[]
  maintenanceRequests MaintenanceRequest[]
  messages            Message[]
  applicants          Applicant[]
  listings            Listing[]
  showings            Showing[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([propertyProfileId])
}

enum UnitStatus {
  VACANT
  LEASED
  NOTICE_GIVEN
  PREPARING
  MAINTENANCE
  LISTED
}

model Lease {
  id               String              @id @default(cuid())
  unitId           String
  unit             Unit                @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenantId         String
  tenant           Tenant              @relation(fields: [tenantId], references: [id])
  status           LeaseStatus         @default(DRAFT)
  startDate        DateTime
  endDate          DateTime
  monthlyRent      Decimal             @db.Decimal(10, 2)
  securityDeposit  Decimal?            @db.Decimal(10, 2)
  paymentDueDay    Int                 @default(1)
  lateFeeAmount    Decimal?            @db.Decimal(10, 2)
  lateFeeGraceDays Int                 @default(5)
  // Contract management
  contractStatus   LeaseContractStatus @default(NONE)
  contractFileUrl  String?
  contractFileName String?
  contractSentAt   DateTime?
  contractSignedAt DateTime?
  contractNotes    String?
  // Currency for rent invoicing
  currency         String              @default("USD")
  // Applicant origin
  applicantId          String?
  applicant            Applicant?      @relation(fields: [applicantId], references: [id])
  // Rudimentary signing
  signingToken         String?         @unique
  tenantSignatureName  String?
  tenantSignatureIp    String?
  tenantSignedAt       DateTime?
  ownerSignatureName   String?
  ownerSignedAt        DateTime?
  // Move-in milestone
  keysHandedOverAt     DateTime?
  tenantCharges    TenantCharge[]
  tenantPayments   TenantPayment[]
  tenantFiles      TenantFile[]
  invoices         Invoice[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([unitId])
  @@index([tenantId])
}

enum LeaseContractStatus {
  NONE
  DRAFTING
  READY
  SENT
  SIGNED
  COUNTERSIGNED
}

enum LeaseStatus {
  DRAFT
  ACTIVE
  EXPIRING_SOON
  MONTH_TO_MONTH
  TERMINATED
  EXPIRED
}

model Tenant {
  id                       String                   @id @default(cuid())
  userId                   String
  clerkUserId              String?
  name                     String
  email                    String
  phone                    String?
  emergencyName            String?
  emergencyPhone           String?
  portalInviteStatus       PortalInviteStatus       @default(NONE)
  leases                   Lease[]
  tenantFiles              TenantFile[]
  messages                 Message[]
  tenantCharges            TenantCharge[]
  tenantPayments           TenantPayment[]
  tenantPaymentSuggestions TenantPaymentSuggestion[]
  maintenanceRequests      MaintenanceRequest[]
  invoices                 Invoice[]
  convertedFromApplicant   Applicant?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt

  @@index([userId])
  @@unique([userId, email])
}

enum PortalInviteStatus {
  NONE
  INVITED
  ACTIVE
}

model TenantFile {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leaseId     String?
  lease       Lease?         @relation(fields: [leaseId], references: [id])
  fileType    TenantFileType
  fileName    String
  fileUrl     String
  fileSize    Int?
  notes       String?
  uploadedBy  String
  createdAt   DateTime       @default(now())
}

enum TenantFileType {
  LEASE_AGREEMENT
  ID_DOCUMENT
  PAY_STUB
  CREDIT_REPORT
  INSPECTION_REPORT
  MOVE_IN_PHOTOS
  MOVE_OUT_PHOTOS
  INSURANCE
  OTHER
}

model Message {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unitId         String
  unit           Unit     @relation(fields: [unitId], references: [id])
  subject        String?
  senderRole     String
  body           String
  isRead         Boolean  @default(false)
  attachmentUrl  String?
  attachmentName String?
  createdAt      DateTime @default(now())

  @@index([tenantId, unitId])
}

// ── Tenant ledger ────────────────────────────────────────────────────────────
// balance = SUM(active TenantCharge.amount) - SUM(TenantPayment.amount)
// Forgiven charges are excluded from the balance (forgivenAt IS NOT NULL).
// Payments are attributed to a tenant, not to a specific charge.

model TenantCharge {
  id                   String      @id @default(cuid())
  leaseId              String
  lease                Lease       @relation(fields: [leaseId], references: [id])
  tenantId             String
  tenant               Tenant      @relation(fields: [tenantId], references: [id])
  type                 ChargeType
  description          String?     // required for MAINTENANCE/OTHER; optional for RENT/LATE_FEE
  amount               Decimal     @db.Decimal(10, 2)
  dueDate              DateTime
  // Forgiveness — soft nullability, not deletion, preserves audit trail
  forgivenAt           DateTime?
  forgivenBy           String?     // userId of manager who forgave
  forgivenReason       String?
  // Optional back-link to source maintenance job
  maintenanceRequestId String?
  maintenanceRequest   MaintenanceRequest? @relation(fields: [maintenanceRequestId], references: [id])
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@index([leaseId])
  @@index([tenantId])
  @@index([tenantId, forgivenAt]) // fast active-charge queries
}

enum ChargeType {
  RENT
  LATE_FEE
  MAINTENANCE
  UTILITY
  DEPOSIT
  OTHER
}

model TenantPayment {
  id            String       @id @default(cuid())
  leaseId       String?
  lease         Lease?       @relation(fields: [leaseId], references: [id])
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  amount        Decimal      @db.Decimal(10, 2)
  paidDate      DateTime
  // Optional — null when recorded manually without a matched bank transaction
  transactionId String?      @unique  // one transaction can only be attributed once
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  paymentMethod String?
  notes         String?
  sourceDeleted Boolean      @default(false)  // true when the linked transaction was deleted
  voidedAt      DateTime?                     // set when manager voids this payment
  voidedBy      String?                       // userId of manager who voided
  voidReason    String?                       // optional reason
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([leaseId])
  @@index([tenantId])
  @@index([transactionId])
}

// Suggested payment attribution — created post-import, reviewed by manager
model TenantPaymentSuggestion {
  id            String                      @id @default(cuid())
  userId        String                      // property owner — for auth scoping
  transactionId String                      // the incoming bank transaction
  transaction   Transaction                 @relation(fields: [transactionId], references: [id])
  tenantId      String
  tenant        Tenant                      @relation(fields: [tenantId], references: [id])
  leaseId       String?
  confidence    String                      // 'high' | 'medium'
  reasoning     String                      // human-readable explanation
  status        TenantPaymentSuggestionStatus @default(PENDING)
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  @@index([userId, status])
  @@index([transactionId])
}

enum TenantPaymentSuggestionStatus {
  PENDING
  ACCEPTED
  DISMISSED
}

model MaintenanceRequest {
  id            String              @id @default(cuid())
  unitId        String
  unit          Unit                @relation(fields: [unitId], references: [id])
  tenantId      String?
  tenant        Tenant?             @relation(fields: [tenantId], references: [id])
  title         String
  description   String
  priority      MaintenancePriority @default(MEDIUM)
  status        MaintenanceStatus   @default(OPEN)
  scheduledDate DateTime?
  completedDate DateTime?
  cost           Decimal?            @db.Decimal(10, 2)
  vendorName     String?
  transactionId  String?
  tenantCharges  TenantCharge[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([unitId])
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

enum MaintenanceStatus {
  OPEN
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ── Applicant pipeline ───────────────────────────────────────────────────────

model Applicant {
  id                  String            @id @default(cuid())
  userId              String            // property owner
  propertyProfileId   String
  propertyProfile     PropertyProfile   @relation(fields: [propertyProfileId], references: [id], onDelete: Cascade)
  unitId              String?
  unit                Unit?             @relation(fields: [unitId], references: [id])

  // Contact info
  name                String
  email               String
  phone               String?

  // Application details
  status              ApplicantStatus   @default(INQUIRY)
  source              String?           // "zillow", "referral", "walk-in", etc.
  desiredMoveIn       DateTime?
  desiredRent         Decimal?          @db.Decimal(10, 2)
  currentEmployer     String?
  annualIncome        Decimal?          @db.Decimal(12, 2)
  notes               String?

  // Screening
  creditScore         Int?
  backgroundCheck     String?           // "passed", "failed", "pending", null
  references          Json?             // array of { name, phone, relationship }

  // Listing link
  listingId           String?
  listing             Listing?          @relation(fields: [listingId], references: [id])

  // Self-service application data
  applicationData     Json?             // structured form submission

  // Screening consent
  screeningConsentAt  DateTime?
  screeningConsentIp  String?

  // Future screening API integration (nullable placeholders)
  screeningRequestId  String?
  screeningProvider   String?
  screeningReportUrl  String?

  // Conversion
  convertedToTenantId String?           @unique
  convertedToTenant   Tenant?           @relation(fields: [convertedToTenantId], references: [id])
  convertedAt         DateTime?
  rejectedAt          DateTime?
  rejectedReason      String?

  documents           ApplicantDocument[]
  showings            Showing[]
  leases              Lease[]
  invoices            Invoice[]

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([userId])
  @@index([propertyProfileId])
  @@index([status])
}

enum ApplicantStatus {
  INQUIRY
  APPLICATION_SENT
  APPLIED
  SCREENING
  APPROVED
  LEASE_OFFERED
  LEASE_SIGNED
  REJECTED
  WITHDRAWN
}

model ApplicantDocument {
  id           String    @id @default(cuid())
  applicantId  String
  applicant    Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  fileType     String    // "proof_of_income" | "proof_of_residence" | "government_id" | "bank_statement" | "employment_letter" | "reference_letter" | "other"
  requestLabel String?   // custom label when fileType = "other", or display override
  status       String    @default("uploaded") // "requested" | "uploaded"
  uploadToken  String?   @unique              // HMAC token for ad-hoc upload links
  tokenExpiresAt DateTime?
  fileName     String    @default("")
  fileUrl      String    @default("")
  fileSize     Int?
  notes        String?
  uploadedBy   String    @default("") // userId or "applicant"
  createdAt    DateTime  @default(now())

  @@index([applicantId])
  @@index([uploadToken])
}

model Listing {
  id              String    @id @default(cuid())
  unitId          String
  unit            Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  userId          String    // property owner, for auth scoping

  title           String
  description     String?
  monthlyRent     Decimal   @db.Decimal(10, 2)
  availableDate   DateTime?
  petPolicy       String?   // "allowed", "case-by-case", "no-pets"
  photos          Json      @default("[]") // string[] of URLs
  amenities       String?   // free-text or comma-separated

  publicSlug      String    @unique
  isActive        Boolean   @default(true)

  applicationFee  Decimal?  @db.Decimal(10, 2)
  screeningFee    Decimal?  @db.Decimal(10, 2)
  requiredDocs    Json      @default("[]") // string[] of doc type keys

  applicants      Applicant[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([unitId])
}

model Showing {
  id            String        @id @default(cuid())
  applicantId   String
  applicant     Applicant     @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  unitId        String
  unit          Unit          @relation(fields: [unitId], references: [id])
  scheduledAt   DateTime
  durationMin   Int           @default(30)
  status        ShowingStatus @default(PROPOSED)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([applicantId])
  @@index([unitId])
}

enum ShowingStatus {
  PROPOSED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}
